# medialab DEV root env template.
# Copy to .env.dev, then load it when running the dev overlay, e.g.:
#   docker compose --env-file .env.dev -f docker-compose.yml -f docker-compose.dev.yml up --build
#
# .env.dev is gitignored.

# Namespaces all dev containers/network/volumes so they never collide with the
# prod project (name: medialab in docker-compose.yml).
COMPOSE_PROJECT_NAME=medialab-dev

# A SEPARATE test media directory - never point dev at the real prod media root,
# or dev downloads/renames would touch prod's library. Use a small throwaway dir.
# Windows host path, e.g. F:\MediaDev
MEDIA_HOST_DIR_DEV=
